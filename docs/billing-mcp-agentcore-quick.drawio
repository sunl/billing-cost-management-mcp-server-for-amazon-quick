                <mxCell id="legend-title" value="&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;How it works&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="1211" y="190" width="300" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="step-1-legend" value="" style="group;fontFamily=Helvetica;" parent="1" connectable="0" vertex="1">
                    <mxGeometry x="1211" y="240" width="580" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="step-1-badge-legend" value="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" parent="step-1-legend" vertex="1">
                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="step-1-desc-legend" value="&lt;div&gt;&lt;b&gt;User asks a cost question&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Business user types a natural-language query in the Amazon Quick chat agent (e.g. &amp;quot;last month&amp;#39;s cost by service&amp;quot;).&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="step-1-legend" vertex="1">
                    <mxGeometry x="52" width="528" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="step-2-legend" value="" style="group;fontFamily=Helvetica;" parent="1" connectable="0" vertex="1">
                    <mxGeometry x="1211" y="350" width="580" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="step-2-badge-legend" value="2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" parent="step-2-legend" vertex="1">
                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="step-2-desc-legend" value="&lt;div&gt;&lt;b&gt;Quick fetches an OAuth 2.0 token&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;The Quick MCP connector exchanges its M2M client credentials for a short-lived JWT access token at the Cognito token endpoint.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="step-2-legend" vertex="1">
                    <mxGeometry x="52" width="528" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="step-3-legend" value="" style="group;fontFamily=Helvetica;" parent="1" connectable="0" vertex="1">
                    <mxGeometry x="1211" y="460" width="580" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="step-3-badge-legend" value="3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" parent="step-3-legend" vertex="1">
                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="step-3-desc-legend" value="&lt;div&gt;&lt;b&gt;MCP call reaches AgentCore Runtime&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Streamable-HTTP request with Bearer JWT hits the AgentCore Runtime endpoint. The JWT authorizer validates the token against the Cognito JWKS and checks allowedClients.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="step-3-legend" vertex="1">
                    <mxGeometry x="52" width="528" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="step-4-legend" value="" style="group;fontFamily=Helvetica;" parent="1" connectable="0" vertex="1">
                    <mxGeometry x="1211" y="570" width="580" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="step-4-badge-legend" value="4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" parent="step-4-legend" vertex="1">
                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="step-4-desc-legend" value="&lt;div&gt;&lt;b&gt;AgentCore runs the MCP server container&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;AgentCore pulls the ARM64 Billing MCP Server image from ECR and invokes the requested tool (one of 25 billing tools) over stateless streamable-HTTP on port 8000.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="step-4-legend" vertex="1">
                    <mxGeometry x="52" width="528" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="step-5-legend" value="" style="group;fontFamily=Helvetica;" parent="1" connectable="0" vertex="1">
                    <mxGeometry x="1211" y="680" width="580" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="step-5-badge-legend" value="5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" parent="step-5-legend" vertex="1">
                    <mxGeometry y="2" width="40" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="step-5-desc-legend" value="&lt;div&gt;&lt;b&gt;Tool calls AWS cost APIs via boto3&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Using the AgentCore execution role credentials, the MCP tool calls Cost Explorer, Budgets, or Compute Optimizer and streams the result back to Amazon Quick for rendering in the chat.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" parent="step-5-legend" vertex="1">
                    <mxGeometry x="52" width="528" height="120" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>